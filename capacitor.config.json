{
  "appId": "app.scoreplace",
  "appName": "scoreplace",
  "webDir": "www",
  "zoomEnabled": true,
  "server": {
    "hostname": "scoreplace.app",
    "iosScheme": "https",
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1000,
      "launchAutoHide": true,
      "launchFadeOutDuration": 300,
      "backgroundColor": "#0f0f23",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "FirebaseAuthentication": {
      "skipNativeAuth": true,
      "providers": ["google.com", "phone"]
    },
    "FirebaseMessaging": {
      "presentationOptions": []
    }
  }
}
