# Template do .env pro VPS (docker-compose). O bootstrap.sh substitui os
# __PLACEHOLDERS__ por valores gerados e grava o .env real (que NÃO é commitado).
#
# Se for preencher à mão: troque __DOMAIN__, __POSTGRES_PASSWORD__ e
# __AUTHENTICATION_API_KEY__ (gere com `openssl rand -hex 32`).

# ─── Público / TLS ────────────────────────────────────────────────────────
DOMAIN=__DOMAIN__
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=https://__DOMAIN__

# ─── Auth (a mesma chave usada pelo Cloud Function e pelo /manager) ───────
AUTHENTICATION_API_KEY=__AUTHENTICATION_API_KEY__

# ─── Postgres (rodando no mesmo compose, host = "postgres") ───────────────
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:__POSTGRES_PASSWORD__@postgres:5432/evolution?schema=public
DATABASE_CONNECTION_CLIENT_NAME=evolution_scoreplace
# CRÍTICO: salva a sessão do WhatsApp no banco (o backup do Postgres preserva o pareamento).
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=false
DATABASE_SAVE_MESSAGE_UPDATE=false
DATABASE_SAVE_DATA_CONTACTS=false
DATABASE_SAVE_DATA_CHATS=false
DATABASE_SAVE_DATA_LABELS=false
DATABASE_SAVE_DATA_HISTORIC=false

# ─── Cache (sem Redis; cache local em memória) ────────────────────────────
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

# ─── Logs / Localização ───────────────────────────────────────────────────
LOG_LEVEL=ERROR,WARN
LOG_COLOR=false
LOG_BAILEYS=error
LANGUAGE=pt-BR
DEL_INSTANCE=false
QRCODE_LIMIT=10
TELEMETRY=false

# ─── Backup pro Google Drive (lido pelo pg-backup.sh via systemd) ─────────
GDRIVE_REMOTE=gdrive
GDRIVE_FOLDER=scoreplace-wa-backups
RETENTION_DAYS=7
