rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────

    // Authenticated user's email, lowercased. Empty string when unavailable.
    function authEmail() {
      return request.auth != null && request.auth.token.email != null
        ? request.auth.token.email.lower() : '';
    }

    // Caller is an admin of the tournament: creator, current organizer, or
    // an active co-host. Caminho normal: email denormalizado em adminEmails[].
    // Caminho de recovery (v1.6.68): adminEmails vazio ou ausente (bug v1.6.66
    // que apagava o campo ao salvar objeto parcial) — cai no organizerEmail
    // declarado como fallback, permitindo que o organizador salve e restaure
    // o campo. A recovery em background (_recoverWipedAdminEmails) repopula
    // adminEmails na próxima sessão para voltar ao caminho normal.
    function isTournamentAdmin(data) {
      // v1.8.99: uid como fonte primária de autenticação
      return request.auth != null && (
        // Caminho uid: creatorUid (mais confiável, imutável)
        (data.creatorUid is string && data.creatorUid == request.auth.uid)
        // v2.8.79: Caminho adminUids — co-hosts ativos por UID (cobre co-host
        // com email '' / conta por telefone). UID é a identidade primária.
        || (data.adminUids is list && data.adminUids.size() > 0
            && request.auth.uid in data.adminUids)
        // Caminho adminEmails: backward compat + co-hosts com email
        || (authEmail() != '' && data.adminEmails is list
            && data.adminEmails.size() > 0 && authEmail() in data.adminEmails)
        // Recovery: adminEmails vazio → organizerEmail
        || (authEmail() != ''
            && !(data.adminEmails is list && data.adminEmails.size() > 0)
            && data.organizerEmail is string
            && data.organizerEmail.lower() == authEmail())
      );
    }

    // Keys legitimately touched by the enroll/deenroll transactions when run
    // by a non-admin (i.e. a participant joining or leaving). Anything
    // outside this set requires admin rights.
    function isEnrollmentOnlyDiff() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['participants', 'memberUids', 'status', 'teamOrigins',
          // v2.1.5: inscrição tardia (standby/expand) — um NOVO inscrito que
          // ainda não está em participants escreve a si mesmo na lista de
          // espera. isParticipantBracketDiff exige já-ser-participante, então
          // sem isto a escrita era negada (permission-denied silencioso) e o
          // inscrito via "lista de espera" localmente mas nada persistia.
          'standbyParticipants', 'waitlist']);
    }

    // Participante aceita convite de co-organização (muda seu próprio status
    // de 'pending' para 'active' em coHosts + atualiza adminEmails).
    // Só permitido para quem já é participante do torneio (memberUids).
    function isCoHostAcceptanceDiff() {
      return isTournamentParticipant(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['coHosts', 'adminEmails']);   // v1.2.2: memberEmails saiu do schema
    }

    // Participant of the tournament.
    // v1.2.2: UID ONLY. O fallback por memberEmails saiu — participante é quem está em
    // memberUids, e pronto. Ele existia pra torneio legado sem memberUids: não há mais
    // nenhum (todos os docs têm memberUids populado). Fallback num GATE de permissão é o
    // pior lugar pra ter rede de segurança: e-mail é atributo do perfil (a pessoa troca),
    // não identidade. Ver [[project_uid_primary_identity]].
    function isTournamentParticipant(data) {
      return request.auth != null
        && data.memberUids is list
        && request.auth.uid in data.memberUids;
    }
    // v1.8.65: usuário pode gerenciar seus próprios emails vinculados
    function isOwnLinkedEmailDiff() {
      return request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedEmails']);
    }

    // v1.8.62: admin por uid (creatorUid) — fallback para organizadores phone-only.
    function isTournamentAdminByUid(data) {
      return request.auth != null
        && data.creatorUid is string
        && data.creatorUid == request.auth.uid;
    }

    // v0.17.24: Diff que participantes podem fazer. Lista positiva expandida
    // após investigação de todos os campos tocados por _advanceWinner,
    // _maybeFinishElimination, _closeRound (Suíço/Liga), auto check-in,
    // logAction, sitOutHistory, etc. — paths que podem rodar como side
    // effect quando participante aprova ou lança placar.
    function isParticipantBracketDiff() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          // Bracket / scoring / aprovação de resultado
          'matches', 'rounds', 'groups', 'rodadas', 'thirdPlaceMatch',
          'currentStage', 'classification', 'standings',
          // Suíço (transição de stage quando última rodada fecha)
          'swissStandings', 'swissRoundsData', 'swissEliminated',
          // Liga / Rei-Rainha
          'sitOutHistory', 'lastAutoDrawAt',
          // Visibilidade do sorteio (set quando rodada fecha)
          'drawVisibility',
          // Check-in / presença / lista de espera em torneio
          'checkedIn', 'absent', 'tournamentStarted',
          'standbyParticipants', 'waitlist',
          // Activity log (logAction escreve em t.history)
          'history',
          // Timestamps
          'updatedAt', 'lastModified',
          // Liga: toggle ativado/desativado pra próximo sorteio
          'ligaActive', 'ligaInactive',
          // Polls: votação de decisão (cada participante vota uma vez)
          'pollNotifications', 'polls', 'activePollId',
          // Enquete do organizador (📊): inscritos votam gravando opinionPolls[].votes.
          // BUG (Confra): sem este campo na lista, o voto do PARTICIPANTE era
          // rejeitado com permission-denied — só o organizador (admin) conseguia
          // votar. O _save engolia o erro e o toast mentia "voto registrado".
          'opinionPolls',
          // W.O. apontado por participante (wo-claim.js): jogador aponta a falta,
          // o outro lado confirma/contesta. Campo top-level novo que o PARTICIPANTE
          // grava → precisa estar aqui (classe do bug Confra do opinionPolls).
          'woClaims',
          // Categorias notificadas (auto-assign comunica ao participante)
          'categoryNotifications',
          // Flags internas setadas em fim de torneio / transições
          '_finishNotified', '_roundCloseAt',
          // Status — pode mudar pra 'finished' quando última partida aprovada
          'status',
          // Inscrição — overlap com isEnrollmentOnlyDiff
          'participants', 'teamOrigins',
          // v1.8.99: memberUids sempre recomputado em saveTournament
          'memberUids',
          // Convites de dupla pendentes (participante envia/aceita/cancela)
          'pairRequests',
          // v2.7.75: pedidos de vínculo/mescla pendentes — o usuário real aceita
          // (assume a vaga do genérico) ou recusa, alterando pendingMerges.
          'pendingMerges',
          // v2.7.84: nextDrawAt é um índice DERIVADO recomputado em TODO save (cliente
          // e servidor). Qualquer save de participante (placar, convite de dupla, etc.)
          // recalcula esse campo — sem permiti-lo, a regra rejeitava o save inteiro
          // (ex.: convite de dupla do participante não persistia → sem botão de aceite).
          'nextDrawAt'
        ]);
    }

    // ─── Tournaments ─────────────────────────────────────────────────────────
    // discoveryFeed: coleção leve de RESUMO dos torneios públicos, mantida
    // exclusivamente pela Cloud Function `syncDiscoveryFeed` (Admin SDK, que
    // ignora estas rules). Serve só como GATILHO de tempo real + resumo para a
    // descoberta — a fonte de verdade continua sendo `tournaments`. Leitura
    // pública (é descoberta), escrita bloqueada para clientes.
    match /discoveryFeed/{tournamentId} {
      allow read: if true;
      allow write: if false;
    }

    match /tournaments/{tournamentId} {
      // Anonymous users: only public tournaments. Authenticated users may
      // read any tournament (needed for invite links and enroll/deenroll
      // transactions, which have to read before writing). Private
      // tournaments remain hidden from unauth visitors.
      allow read: if (resource.data.isPublic == true) || (request.auth != null);

      // Create: the caller must be the declared creator. Prevents forging
      // tournaments on someone else's behalf. v2.8.79: aceita uid (creatorUid)
      // como caminho primário — criador com conta por telefone tem email ''.
      allow create: if request.auth != null
        && (
          (request.resource.data.creatorUid is string
            && request.resource.data.creatorUid == request.auth.uid)
          || (authEmail() != '' && request.resource.data.creatorEmail is string
            && request.resource.data.creatorEmail.lower() == authEmail())
        );

      // Update permitido em 3 caminhos:
      //   1. Admin (creator/organizer/co-host) — qualquer mudança.
      //      isTournamentAdmin inclui fallback p/ organizerEmail quando
      //      adminEmails está vazio (recovery do bug v1.6.66).
      //   2. Qualquer authed pode fazer enrollment-only diff (entrar/sair)
      //   3. Participante pode atualizar campos do bracket (placar, check-in,
      //      aprovação de resultado, voto em poll, etc.) — lista positiva
      //      em isParticipantBracketDiff. Bloqueia mudanças em nome/datas/
      //      formato/regras/organizador/etc. mesmo pra participantes.
      allow update: if request.auth != null
        && (
          isTournamentAdmin(resource.data)
          // v1.8.62: admin por uid (organizador phone-only sem email)
          || isTournamentAdminByUid(resource.data)
          || isEnrollmentOnlyDiff()
          || (isTournamentParticipant(resource.data) && isParticipantBracketDiff())
          || isCoHostAcceptanceDiff()
        );

      // Delete: admins only.
      allow delete: if request.auth != null
        && (isTournamentAdmin(resource.data) || isTournamentAdminByUid(resource.data));

      // ─── Resultado por JOGO em doc próprio (linha 4.1, project_match_result_docs) ───
      // Cada jogo tem seu placar/consenso em tournaments/{id}/results/{matchId}.
      // Escopo PER-JOGO: só os participantes DAQUELE jogo (ou o organizador) escrevem.
      // O subdoc carrega `playerUids` = uids dos dois lados do jogo (definidos por
      // caminho de confiança: o sorteio/avanço, que é admin). O participante do jogo
      // pode gravar o RESULTADO se seu uid está em playerUids E sem alterar playerUids
      // (não pode se auto-incluir). Admin (org/co-host) pode tudo (definir playerUids
      // no sorteio, resolver disputa, refazer). Leitura = quem pode ler o torneio.
      match /results/{matchId} {
        function parentT() {
          return get(/databases/$(database)/documents/tournaments/$(tournamentId)).data;
        }
        function isAdminOf(pt) { return isTournamentAdmin(pt) || isTournamentAdminByUid(pt); }
        // `request.auth != null` PRIMEIRO no OR: curto-circuita sem o get() do
        // parentT() → deixa a query collectionGroup de `results` (Fase B: ler os
        // jogos de um uid sem carregar torneio) eficiente. Semântica idêntica à
        // ordem anterior (authed já lia qualquer result subdoc); só evita 1 get()
        // por doc na listagem. Público (sem auth) ainda cai no parentT().isPublic.
        allow read: if (request.auth != null) || (parentT().isPublic == true);
        // Create: só admin (o sorteio cria o doc do jogo já com playerUids).
        allow create: if request.auth != null && isAdminOf(parentT());
        // Update: admin OU participante DAQUELE jogo (uid em playerUids) que NÃO mexe
        // no roster (playerUids imutável pra participante).
        allow update: if request.auth != null && (
          isAdminOf(parentT())
          || ( (resource.data.playerUids is list) && (request.auth.uid in resource.data.playerUids)
               && (request.resource.data.playerUids == resource.data.playerUids) )
        );
        allow delete: if request.auth != null && isAdminOf(parentT());
      }

      // ─── Busca ativa letzplay do organizador (anti-gato) ───────────────────
      // tournaments/{id}/letzplayScans/{uid} — o organizador varre o PERFIL
      // PÚBLICO letzplay dos inscritos que autorizaram (categoria/nível) via a
      // extensão. Só o admin (org/co-host) escreve; qualquer authed que pode ler
      // o torneio lê (co-organizadores veem o mesmo).
      match /letzplayScans/{scanUid} {
        function parentTs() {
          return get(/databases/$(database)/documents/tournaments/$(tournamentId)).data;
        }
        allow read: if (request.auth != null) || (parentTs().isPublic == true);
        allow create, update: if request.auth != null
          && (isTournamentAdmin(parentTs()) || isTournamentAdminByUid(parentTs()));
        allow delete: if request.auth != null
          && (isTournamentAdmin(parentTs()) || isTournamentAdminByUid(parentTs()));
      }
    }

    // ─── Histórico letzplay: 1 doc por COMPETIÇÃO, 1 doc por PARTIDA ──────────
    // letzplayTournaments/{compId}/matches/{gid} — mesmo molde dos nossos jogos
    // (tournaments/{id}/results/{matchId}), que é como o letzplay também organiza.
    //
    // POR QUE NÃO É UM DOC POR USUÁRIO: uma partida do letzplay tem 4 pessoas, então ela
    // é importada até 4 vezes (uma por perspectiva). Como doc compartilhado, o mesmo jogo
    // vira UM doc (o gid é neutro de perspectiva — ver js/letzplay-model.js) e importar
    // uma pessoa já preenche o pedaço dos parceiros/adversários. Como doc por usuário,
    // seria o mesmo jogo repetido 4x, com o placar invertido em metade das cópias.
    //
    // Dado é PÚBLICO no letzplay (qualquer um lê o perfil de qualquer um sem login), então
    // leitura/escrita por qualquer authed — mesma política de letzplayScans. A whitelist
    // de chaves é o que impede um cliente de pendurar campo arbitrário.
    //
    // A leitura do histórico de alguém é collectionGroup('matches') com
    // where('players','array-contains', handle) — o mesmo padrão que `results` usa pra ler
    // os jogos de um uid sem carregar o torneio. Por isso `allow read` NÃO faz get() no
    // pai: um get() por doc tornaria a listagem cara.
    match /letzplayTournaments/{compId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasOnly(['compId', 'club', 'kind', 'letzId', 'name', 'categoryRaw', 'sport', 'standings', 'logo', 'updatedAt', 'seenFrom']);
      allow delete: if false;   // histórico é acervo: ninguém apaga pelo cliente

      match /matches/{gid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.resource.data.keys().hasOnly(['gid', 'comp', 'club', 'kind', 'sport', 'date', 'dateNum', 'round', 'teams', 'winner', 'players', 'updatedAt', 'seenFrom']);
        allow delete: if false;
      }
    }

    // ─── Scan público letzplay POR PESSOA (uid), global e reutilizável ─────────
    // letzplayScans/{uid} — o organizador busca o PERFIL PÚBLICO letzplay do inscrito
    // (categoria/nível/totais) via extensão e grava aqui, keyed por uid. Puxou uma vez,
    // vale pra TODOS os torneios (não precisa re-puxar). Dado é público no letzplay.
    // Leitura: qualquer authed. Escrita: qualquer authed (organizador) — dado público.
    match /letzplayScans/{scanUid} {
      allow read: if request.auth != null;
      // scannedByName + tournamentId/Name identificam quem/qual torneio puxou; fullImport
      // é o histórico COMPLETO (só no scan "completo") que vira o letzplayImport do dono.
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasOnly(['handle', 'scan', 'scannedAt', 'scannedBy', 'scannedByName', 'tournamentId', 'tournamentName', 'fullImport']);
      allow delete: if request.auth != null;
    }

    // ─── User profiles ───────────────────────────────────────────────────────
    // Diff that only touches the friend-relationship arrays. Used to let a
    // caller modify another user's friends / friendRequestsReceived /
    // friendRequestsSent arrays WITHOUT being able to touch profile fields.
    // The sendFriendRequest / accept / reject / cancel flows need this because
    // each one updates the OTHER party's arrays.
    function isFriendArrayDiff() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['friends', 'friendRequestsSent', 'friendRequestsReceived']);
    }
    match /users/{userId} {
      // Authenticated only — strips PII (email, phone, preferredCeps,
      // fcmToken, etc.) from anonymous visitors. Needed for friend search
      // (searchUsers range query) and participant detail views.
      allow read: if request.auth != null;

      // v1.2.9 — CAMPOS PRIVILEGIADOS: só o Admin SDK (Cloud Functions) escreve.
      //
      // SEQUESTRO DE CONTA (achado e provado no emulador em 15/jul/2026): o `allow update`
      // dizia "owner may touch anything" e só se preocupava com edição CROSS-user. Mas
      // `mergedInto` é lido pela CF resolveMergedLogin, que devolve um CUSTOM TOKEN do uid
      // apontado. Então bastava a pessoa escrever no PRÓPRIO perfil
      //     users/{meu-uid} = { mergedInto: "<uid-da-vítima>" }
      // e chamar resolveMergedLogin pra entrar na conta de qualquer um. Um campo que o
      // servidor TRATA COMO PROVA nunca pode ser escrito por quem ele autoriza.
      //
      // Bloquear não quebra nada: nenhum caminho do cliente escreve estes campos (0 writes
      // no js/ — só leituras), e o Admin SDK ignora rules por definição.
      //   mergedInto/mergedAt → prova de merge (resolveMergedLogin dá custom token)
      //   plan/planExpiresAt  → assinatura Pro (só o webhook do Stripe pode conceder)
      function privilegedUserFields() {
        return ['mergedInto', 'mergedAt', 'plan', 'planExpiresAt'];
      }
      function touchesPrivileged() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(privilegedUserFields());
      }

      // Create: only the user themselves (first-time profile creation).
      // O bloqueio precisa valer no CREATE também — senão o buraco reabre: apagar o próprio
      // perfil e recriá-lo já com `mergedInto` seria o mesmo sequestro por outro caminho.
      allow create: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(privilegedUserFields());

      // Update: owner may touch anything EXCEPT the privileged fields above; any other
      // authenticated user may update ONLY the three friend arrays (so sendFriendRequest
      // can add the caller's uid to the target's friendRequestsReceived, accept can
      // add caller to target's friends, etc.). Prevents cross-user edits of
      // profile PII while keeping the friendship flow working.
      allow update: if request.auth != null
        && ((request.auth.uid == userId && !touchesPrivileged()) || isFriendArrayDiff());

      // Delete: owner only.
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Notifications — senders create (cross-user), owner manages.
      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }

      // Match history (stats across tournaments + casual matches) — only
      // the user themselves, same as profile.
      match /matchHistory/{matchId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Templates — only owner.
      match /templates/{templateId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Trophies + milestones — owner only (backfill uses Admin SDK, bypasses rules).
      match /trophies/{trophyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /milestones/{milestoneId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── Email verification tokens ───────────────────────────────────────────
    // Criado pelo dono (autenticado) para verificar posse de um email secundário.
    // Leitura pública (token é o segredo). Update público para marcar como verificado.
    match /emailVerifications/{token} {
      allow read: if true;         // token é o segredo — quem tem o link pode ler
      allow create: if request.auth != null; // só autenticados criam
      allow update: if true;       // marcar verified=true após clique no link
    }

    // ─── Casual matches ──────────────────────────────────────────────────────
    // Public read so anonymous QR / room-code joins work — no PII. Writes
    // require auth; the claim-slot transaction adds uid to playerUids, so
    // we can't scope update to "already-in-playerUids" without breaking the
    // join flow. Left permissive for authenticated users.
    match /casualMatches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Friend requests ─────────────────────────────────────────────────────
    // TODO(security): scope read/write to the request's from/to uids once
    // the doc structure is cemented. Authed-only for now.
    match /friendRequests/{requestId} {
      allow read, write: if request.auth != null;
    }

    // ─── Reports (moderação de UGC — Apple Guideline 1.2) ────────────────────
    // Usuários autenticados criam denúncias de conteúdo (avaliações de locais,
    // etc.). Write-only: a equipe revisa via console/Admin SDK. Ninguém lê,
    // edita ou apaga pelo cliente (evita retaliação/adulteração).
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ─── Login redirects (v1.2.9) — PROVA, escrita só pelo Admin SDK ─────────
    // Quando duas contas do MESMO tipo são fundidas (duas Google, p.ex.), a credencial da
    // absorvida não migra — o Firebase não põe dois provedores do mesmo tipo numa conta, e a
    // conta dela é apagada. Quem loga com aquele e-mail cai numa conta nova e VAZIA. O merge
    // grava aqui `{email|telefone} → ownerUid` e a CF resolveLoginRedirect manda a pessoa pra
    // conta certa via custom token.
    //
    // deny-all TOTAL: este doc concede acesso a uma conta, então é prova. Se o cliente
    // pudesse escrever, bastaria reivindicar o e-mail de outro pra capturar o login dele —
    // que é exatamente por que o redirect NÃO usa `linkedEmails`/`email` do perfil (o cliente
    // escreve esses). A leitura também é fechada: o mapa e-mail→uid é PII.
    // Ver [[project_privileged_fields_never_client_writable]].
    match /loginRedirects/{key} {
      allow read, write: if false;
    }

    // ─── Mail (firestore-send-email extension) ───────────────────────────────
    match /mail/{mailId} {
      allow read: if false;
      allow write: if request.auth != null;
    }

    // ─── Notif email digest queue (v2.1.19) ──────────────────────────────────
    // E-mails de NOTIFICAÇÃO entram aqui (janela por importância 5/15/30 min) e
    // a Cloud Function flushNotifEmailDigest consolida num e-mail por pessoa.
    // Qualquer autenticado enfileira (mesmo modelo do mail/); leitura/exclusão
    // só pela função (Admin SDK ignora rules).
    match /notif_email_queue/{id} {
      allow read: if false;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ─── WhatsApp queue (Cloud Function processWhatsAppQueue → Evolution API) ──
    // v2.1.15: FALTAVA esta regra — sem ela, toda escrita em whatsapp_queue era
    // NEGADA (default deny), e queueWhatsApp falhava silencioso no try/catch.
    // Resultado: notificação por WhatsApp nunca era enfileirada (fila vazia
    // desde 08/mai), enquanto e-mail (mail/) funcionava. Mesmo modelo do mail/:
    // qualquer autenticado pode enfileirar; o envio é feito pela Cloud Function.
    match /whatsapp_queue/{id} {
      allow read: if false;
      allow write: if request.auth != null;
    }

    // ─── WhatsApp digest queue (v1.16) — acumula 'agrupado', flushWhatsAppDigest junta ──
    match /whatsapp_digest_queue/{id} {
      allow read: if false;
      allow write: if request.auth != null;
    }

    // ─── Email verification codes (v3.0.x) — SERVER-ONLY ──────────────────────
    // sendVerificationCode/verifyEmailCode (Cloud Functions, Admin SDK) gravam e leem o
    // código de confirmação HASHEADO. O cliente NUNCA acessa — senão poderia ler o hash
    // ou forjar a verificação. O default-deny já cobriria; explicitamos pra deixar claro.
    match /emailVerifyCodes/{uid} {
      allow read, write: if false;
    }

    // ─── Magic Links wrapper (v1.0.30-beta) ──────────────────────────────────
    // Cloud Function `sendMagicLink` cria docs aqui com o link Firebase
    // assinado. Usuário NÃO autenticado clica no email, abre /?ml=TOKEN no
    // browser, e o JS do app lê esse doc pra resolver o firebaseLink real e
    // redirecionar. Token é 24 chars random base64url — segredo suficiente
    // pra leitura pública (igual unlisted YouTube link). Escrita só via
    // Admin SDK (Cloud Function bypassa rules).
    match /magicLinks/{token} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Presences (check-ins + planned "I'll play here") ─────────────────────
    // Any authenticated user may read; client filters by visibility and friends.
    // Create: must match caller's uid. Update/delete: owner only.
    // TODO(security): lock reads to friends + public via a denormalized
    // friendUids[] once the feature is validated.
    match /presences/{presenceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ─── Venues (community listings, opcionalmente reivindicáveis) ───────────
    // Qualquer usuário autenticado pode cadastrar um local novo; o dono
    // formal (ownerUid) é uma reivindicação opcional. Leitura pública para
    // descoberta anônima.
    //
    // Create:
    //   - authed, createdByUid == auth.uid
    //   - ownerUid pode ser null (cadastro comunitário) ou == auth.uid
    //     (reivindicação na criação).
    // Update:
    //   - dono formal (ownerUid == auth.uid) pode alterar tudo
    //   - se não há dono, qualquer authed pode alterar desde que não promova
    //     outra pessoa a dono (ownerUid deve permanecer null ou virar self)
    //   - qualquer authed pode incrementar viewCount/lastViewedAt
    // Delete: dono formal (ownerUid == auth.uid).
    function isViewCountBump() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['viewCount', 'lastViewedAt']);
    }
    function venueOwnershipOk() {
      return request.resource.data.ownerUid == null
        || request.resource.data.ownerUid == request.auth.uid;
    }
    match /venues/{venueId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.createdByUid == request.auth.uid
        && venueOwnershipOk();
      allow update: if request.auth != null
        && (
          resource.data.ownerUid == request.auth.uid
          || isViewCountBump()
          || (resource.data.ownerUid == null && venueOwnershipOk())
        );
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;

      // Avaliações do local: estrelas (1-5) + texto opcional. Um review por
      // usuário (doc id = uid). Leitura pública para busca anônima. Criar e
      // atualizar só quem é o próprio autor; dono do venue pode moderar.
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && reviewId == request.auth.uid
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;
        allow update: if request.auth != null
          && resource.data.uid == request.auth.uid;
        // Delete: próprio autor OU dono do venue (moderação).
        allow delete: if request.auth != null
          && (
            resource.data.uid == request.auth.uid
            || get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == request.auth.uid
          );
      }

      // Quadras do local:
      //
      // DUAS FASES:
      // 1. FASE COLABORATIVA (venue sem owner): qualquer autenticado adiciona;
      //    cada contribuidor pode editar/apagar APENAS suas próprias entradas.
      // 2. FASE CLAIMED (venue com ownerUid): o dono é o único que adiciona,
      //    edita e apaga quadras. Quando um usuário reivindica o local, ele
      //    "assume tudo" — inclusive as entradas cadastradas pela comunidade
      //    ficam sob sua gestão exclusiva. Contributors originais perdem
      //    acesso de edição (a entrada permanece, mas gerenciada pelo dono).
      //
      // CREATE: permitido se (a) venue não tem dono E o criador é o
      //   contributor, OU (b) venue tem dono e esse dono é o criador.
      // UPDATE/DELETE: mesmo princípio — contributor só quando não há dono;
      //   dono sempre quando existe.
      match /courts/{courtId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.contributorUid == request.auth.uid
          && request.resource.data.sport is string
          && request.resource.data.count is int
          && request.resource.data.count >= 1
          && request.resource.data.count <= 999
          && (
            // Venue sem dono: qualquer autenticado contribui
            !('ownerUid' in get(/databases/$(database)/documents/venues/$(venueId)).data)
            || get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == null
            // OU: venue tem dono e o criador É o dono
            || get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == request.auth.uid
          );
        allow update: if request.auth != null
          && (
            // Venue tem dono: só o dono edita (assume tudo, incluindo
            // entradas que foram feitas por contribuidores antes)
            get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == request.auth.uid
            // OU: venue sem dono e usuário é o contributor original
            || (
              (
                !('ownerUid' in get(/databases/$(database)/documents/venues/$(venueId)).data)
                || get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == null
              )
              && resource.data.contributorUid == request.auth.uid
            )
          );
        allow delete: if request.auth != null
          && (
            get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == request.auth.uid
            || (
              (
                !('ownerUid' in get(/databases/$(database)/documents/venues/$(venueId)).data)
                || get(/databases/$(database)/documents/venues/$(venueId)).data.ownerUid == null
              )
              && resource.data.contributorUid == request.auth.uid
            )
          );
      }
    }
  }
}
