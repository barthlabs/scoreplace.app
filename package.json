{
  "name": "scoreplace-app",
  "version": "1.1.0",
  "private": true,
  "description": "scoreplace.app — vanilla JS SPA. Package.json existe apenas para devDependencies de tooling (Playwright, Lighthouse). NÃO há build step nem bundler — index.html serve js/ e css/ direto.",
  "scripts": {
    "test": "node tests/run-unit.js",
    "test:unit": "node tests/run-unit.js",
    "test:concurrency": "PATH=\"/opt/homebrew/opt/openjdk/bin:$PATH\" firebase emulators:exec --only firestore --config firebase.emulator.json --project demo-scoreplace \"node tests/concurrency/run.js\"",
    "test:rules": "node tests/rules-privileged-fields.test.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "prerender": "node tools/prerender-landing.js",
    "prerender:dry": "node tools/prerender-landing.js --dry-run",
    "lighthouse": "lighthouse https://scoreplace.app/ --quiet --chrome-flags=\"--headless=new --no-sandbox --incognito\" --output=json --output=html --form-factor=mobile --screenEmulation.mobile=true --only-categories=performance,accessibility,best-practices,seo --max-wait-for-load=60000",
    "build:www": "node tools/build-www.js",
    "cap:sync": "node tools/build-www.js && node node_modules/@capacitor/cli/bin/capacitor sync",
    "ext:zip": "bash scripts/build-ext-zip.sh",
    "check:ext": "node scripts/check-ext-version.js",
    "check:cache": "node scripts/check-cache-busters.js",
    "sync:staging": "node tools/sync-staging-from-prod.js",
    "cf:check": "node tools/check-functions-parity.js"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.49.0",
    "firebase": "^12.15.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-social-login": "^8.3.36"
  }
}
