<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Duas metades borda a borda: sacador (azul) à esquerda, recebedor (vermelho) à direita -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Time 1 (azul) -->
        <LinearLayout
            android:id="@+id/half_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@color/half_blue"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="66dp"
            android:paddingBottom="42dp">

            <TextView
                android:id="@+id/point_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="40"
                android:textColor="@color/team_blue"
                android:textSize="72sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/ball_l1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/serve_ball"
                    android:textSize="10sp"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:id="@+id/name_l1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rodrigo"
                    android:textColor="@color/name_blue"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView
                    android:id="@+id/ball_l2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/serve_ball"
                    android:textSize="10sp"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/name_l2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nelson"
                    android:textColor="@color/name_blue_dim"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Time 2 (vermelho) -->
        <LinearLayout
            android:id="@+id/half_right"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@color/half_red"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="66dp"
            android:paddingBottom="42dp">

            <TextView
                android:id="@+id/point_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30"
                android:textColor="@color/team_red"
                android:textSize="72sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/ball_r1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/serve_ball"
                    android:textSize="10sp"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/name_r1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelly"
                    android:textColor="@color/name_red"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView
                    android:id="@+id/ball_r2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/serve_ball"
                    android:textSize="10sp"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/name_r2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zilda"
                    android:textColor="@color/name_red_dim"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Topo: Set, GAMES e placar de games 1 - 2 nas cores dos times -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="12dp">

        <!-- "Aguardando…" quando não há partida (só visível inativo) -->
        <TextView
            android:id="@+id/set_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aguardando…"
            android:textColor="@color/meta"
            android:textSize="10sp"
            android:visibility="gone" />

        <!-- SETS no lugar do rótulo do set: rótulo em cima, "0 - 0" embaixo
             (empilhado — cabe melhor no topo curvo da tela redonda). Mostrado
             quando a partida está ativa. -->
        <LinearLayout
            android:id="@+id/sets_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SETS"
                android:textColor="@color/meta_dim"
                android:textSize="8sp"
                android:letterSpacing="0.15" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">
                <TextView
                    android:id="@+id/sets_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/team_blue"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/dash"
                    android:textSize="12sp"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp" />
                <TextView
                    android:id="@+id/sets_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/team_red"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GAMES"
            android:textColor="@color/meta_dim"
            android:textSize="8sp"
            android:letterSpacing="0.15" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">
            <TextView
                android:id="@+id/games_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="@color/team_blue"
                android:textSize="28sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="@color/dash"
                android:textSize="20sp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp" />
            <TextView
                android:id="@+id/games_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2"
                android:textColor="@color/team_red"
                android:textSize="28sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- Rodapé: Desfazer -->
    <LinearLayout
        android:id="@+id/btn_undo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/undo_pill"
        android:clickable="true"
        android:focusable="true"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↺  Desfazer"
            android:textColor="@color/undo_text"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Fim de jogo: cobre tudo e absorve toques (trava os botões +1).
         ScrollView pra nunca cortar quando há prompt de "Jogar novamente". -->
    <ScrollView
        android:id="@+id/winner_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/winner_scrim"
        android:clickable="true"
        android:focusable="true"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="36sp"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/winner_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VENCEDOR"
                android:textColor="@color/meta"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:layout_marginTop="3dp" />

            <TextView
                android:id="@+id/winner_names"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text=""
                android:textColor="@color/name_blue"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="1dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <TextView
                android:id="@+id/winner_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/meta_dim"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

            <!-- "Jogar novamente?" + Cancelar/Confirmar + toggle Re-sortear.
                 Só casual (canReplay). -->
            <LinearLayout
                android:id="@+id/replay_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jogar novamente?"
                    android:textColor="@color/name_blue"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <TextView
                        android:id="@+id/btn_replay_cancel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Cancelar"
                        android:textColor="@color/undo_text"
                        android:textSize="12sp"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/pill"
                        android:backgroundTint="@color/btn_cancel_bg"
                        android:clickable="true"
                        android:focusable="true" />
                    <TextView
                        android:id="@+id/btn_replay_confirm"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Confirmar"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/pill"
                        android:backgroundTint="@color/btn_confirm_bg"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Re-sortear duplas — só em duplas -->
                <LinearLayout
                    android:id="@+id/reshuffle_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">
                    <Switch
                        android:id="@+id/reshuffle_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Re-sortear duplas"
                        android:textColor="@color/meta"
                        android:textSize="11sp"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</FrameLayout>
